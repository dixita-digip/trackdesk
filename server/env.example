# Copy to server/.env or repo root .env (this server loads both).
# Supabase: Project Settings → API → Project URL and service_role key (server only; never expose in the browser).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
CORS_ORIGIN=http://localhost:5173,https://YOUR-VERCEL-PROJECT.vercel.app,https://*.vercel.app

# Existing optional vars (SMTP, admin, etc.) stay the same.
