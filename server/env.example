# Copy to server/.env or repo root .env (this server loads both).
#
# Vercel: create a project with Root Directory set to `server`, then paste these as Environment Variables.
# Point the frontend (VITE_API_BASE_URL) to https://YOUR-API-PROJECT.vercel.app/api
#
# Supabase: Project Settings → API → Project URL and service_role key (server only; never expose in the browser).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
CORS_ORIGIN=http://localhost:5173,https://YOUR-VERCEL-PROJECT.vercel.app,https://*.vercel.app
# Direct HTTPS URL to tracker .exe. After GitHub Action uploads to bucket "tracker-installers" (public), use:
# TRACKER_INSTALLER_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/tracker-installers/tracker-setup.exe
TRACKER_INSTALLER_URL=
FRONTEND_URL=https://YOUR-VERCEL-PROJECT.vercel.app
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d

# Existing optional vars (SMTP, admin, etc.) stay the same.
