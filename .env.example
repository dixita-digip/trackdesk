# Loaded automatically by Vite from this folder (project root).
# Only names prefixed with VITE_ are exposed to browser code: import.meta.env.VITE_*.

# Optional: public API origin when the app is not served behind the same-origin /api proxy
# (you would need to use this value in src/services/api.js for it to take effect).
# VITE_API_BASE_URL=http://localhost:5000

VITE_API_BASE_URL=http://localhost:5000
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
# Must be a real, verified sender email in SendGrid (Single Sender or Domain). Not "apikey".
SMTP_FROM=your_verified_sender@example.com

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
