# Loaded automatically by Vite from this folder (project root).
# Only names prefixed with VITE_ are exposed to browser code: import.meta.env.VITE_*.

# API base for axios (paths are /systems, /employees, … → combined with baseURL must hit /api/* on the server).
# Local: keep /api so Vite proxies to Express (see vite.config.js).
VITE_API_BASE_URL=/api
# Production when the API is a separate host (e.g. second Vercel project with root directory `server`):
# VITE_API_BASE_URL=https://your-digitracker-api.vercel.app/api
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
# Must be a real, verified sender email in SendGrid (Single Sender or Domain). Not "apikey".
SMTP_FROM=your_verified_sender@example.com

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
