# Copy to desktop-tracker/.env and/or set the same keys in the repo root .env (parent folder).
# The desktop app loads: ../.env → desktop-tracker/.env → cwd/.env
#
# Cloudinary: Settings → Upload → Upload presets → Signing mode: Unsigned (no API secret in app).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=# Optional folder (default trackdesk/screenshots). Use CLOUDINARY_FOLDER= with empty value to omit (use preset folder only).
# CLOUDINARY_FOLDER=trackdesk/screenshots

# Inactivity: no mouse/keyboard (OS idle). Timer stops automatically; modal offers Resume / Dismiss.
# On Windows, idle uses GetLastInputInfo (PowerShell) because Electron powerMonitor often reports 0.
# TRACKER_IDLE_WARNING_SECONDS=60
# TRACKER_IDLE_POLL_MS=15000
# TRACKER_IDLE_SNOOZE_MS=300000
# TRACKER_IDLE_RESUME_SNOOZE_MS=90000
